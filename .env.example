# Kopier denne filen til .env og fyll inn verdiene.
# Vinmonopolet-nøkkelen ligger ALDRI i klienten — den bor i Cloudflare Worker-proxyen.

# URL-en til din Cloudflare Worker-proxy (se README for oppsett)
VITE_PROXY_URL=https://vinkjeller-proxy.DITTBRUKERNAVN.workers.dev

# Delt token mellom klient og proxy. Generer med: openssl rand -hex 32
# Samme verdi settes som Worker-secret (wrangler secret put CLIENT_TOKEN)
# og som GitHub Actions-secret VITE_APP_TOKEN.
VITE_APP_TOKEN=ditt-hemmelige-token-her
